{
  "name": "node-red-bin",
  "version": "3.1.15",
  "description": "Node-RED standalone binaries for all platforms",
  "bin": "src/index.js",
  "repository": {
    "type": "git",
    "url": "git@github.com:digitalnodecom/node-red-bin.git"
  },
  "scripts": {
    "start": "node src/index.js",
    "build": "pkg . --output build/node-red",
    "build:macos-x64": "pkg . --targets node24-macos-x64 --output build/node-red-macos-x64",
    "build:macos-arm64": "pkg . --targets node24-macos-arm64 --output build/node-red-macos-arm64",
    "build:linux-x64": "pkg . --targets node24-linux-x64 --output build/node-red-linux-x64",
    "build:win-x64": "pkg . --targets node24-win-x64 --output build/node-red-win-x64.exe"
  },
  "dependencies": {
    "node-red": "^3.1.0",
    "commander": "^12.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "node_modules/node-red/**/*.js",
    "assets": [
      "node_modules/node-red/public/**/*",
      "node_modules/node-red/red/**/*",
      "node_modules/node-red/nodes/**/*",
      "node_modules/@node-red/**/*"
    ],
    "targets": [
      "node24-macos-x64",
      "node24-macos-arm64",
      "node24-linux-x64",
      "node24-win-x64"
    ]
  }
}
